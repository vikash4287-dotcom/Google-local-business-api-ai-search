{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents an authenticated user profile and subscription status",
      "type": "object",
      "properties": {
        "subscription": {
          "type": "object",
          "properties": {
            "tier": { "type": "string", "enum": ["Free", "Starter", "Agency"] },
            "searchesToday": { "type": "number" },
            "lastSearchDate": { "type": "string" }
          },
          "required": ["tier", "searchesToday", "lastSearchDate"]
        },
        "subscriptionHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "tier": { "type": "string" },
              "date": { "type": "string" },
              "amount": { "type": "number" },
              "currency": { "type": "string" },
              "status": { "type": "string" }
            },
            "required": ["id", "tier", "date", "amount", "currency", "status"]
          }
        }
      }
    },
    "SavedBusiness": {
      "title": "SavedBusiness",
      "description": "A bookmarked or saved lead business in CRM",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Lead ID"
        },
        "name": {
          "type": "string",
          "description": "Business Name"
        },
        "category": {
          "type": "string",
          "description": "Business Category"
        },
        "city": {
          "type": "string",
          "description": "Business City Location"
        },
        "address": {
          "type": "string",
          "description": "Business physical address"
        },
        "phone": {
          "type": "string",
          "description": "Contact phone number"
        },
        "website": {
          "type": "string",
          "description": "Website URL"
        },
        "rating": {
          "type": "number",
          "description": "Average rating of the business"
        },
        "reviewCount": {
          "type": "number",
          "description": "Number of reviews"
        },
        "savedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp when the business was bookmarked"
        },
        "status": {
          "type": "string",
          "enum": ["New", "Contacted", "Interested", "Do Not Contact"],
          "description": "CRM pipeline state of the lead"
        }
      },
      "required": ["id", "name", "category", "city", "savedAt", "status"]
    },
    "SearchHistory": {
      "title": "SearchHistory",
      "description": "Stored user lead search execution log",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Log Entry ID"
        },
        "city": {
          "type": "string",
          "description": "Queried city location"
        },
        "category": {
          "type": "string",
          "description": "Queried category"
        },
        "resultsCount": {
          "type": "number",
          "description": "Total results found"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO formatted search query run time"
        }
      },
      "required": ["id", "city", "category", "resultsCount", "timestamp"]
    },
    "WebsiteAudit": {
      "title": "WebsiteAudit",
      "description": "Detailed website quality and service audit generated by Gemini",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique audit ID" },
        "businessId": { "type": "string", "description": "ID of audited business" },
        "businessName": { "type": "string", "description": "Name of audited business" },
        "website": { "type": "string", "description": "Audited website URL" },
        "score": { "type": "number", "description": "Calculated score (0-100)" },
        "strengths": { "type": "array", "items": { "type": "string" }, "description": "List of key strengths" },
        "weaknesses": { "type": "array", "items": { "type": "string" }, "description": "List of key weaknesses" },
        "recommendedImprovements": { "type": "array", "items": { "type": "string" }, "description": "Actionable improvements" },
        "potentialServicesToSell": { "type": "array", "items": { "type": "string" }, "description": "Up-sell contract services" },
        "estimatedProjectValue": { "type": "string", "description": "Estimated agency contract size" },
        "auditedAt": { "type": "string", "format": "date-time", "description": "When the audit was run" }
      },
      "required": ["id", "businessId", "businessName", "website", "score", "strengths", "weaknesses", "recommendedImprovements", "potentialServicesToSell", "estimatedProjectValue", "auditedAt"]
    },
    "Proposal": {
      "title": "Proposal",
      "description": "Generated agency client pitch proposal document",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique proposal ID" },
        "businessId": { "type": "string", "description": "ID of proposed business" },
        "businessName": { "type": "string", "description": "Name of proposed business" },
        "website": { "type": "string", "description": "Website or digital fallback" },
        "executiveSummary": { "type": "string", "description": "High-level visual pitch summary" },
        "businessProblems": { "type": "array", "items": { "type": "string" }, "description": "Core client service gaps" },
        "websiteIssues": { "type": "array", "items": { "type": "string" }, "description": "Core interface and conversion deficiencies" },
        "reviewAndReputationIssues": { "type": "array", "items": { "type": "string" }, "description": "Identified reputation deficits" },
        "recommendedServices": { "type": "array", "items": { "type": "string" }, "description": "Services pitching to fix" },
        "expectedResults": { "type": "array", "items": { "type": "string" }, "description": "Key estimated business gains" },
        "pricingRecommendations": { "type": "string", "description": "Contract sizing breakdown" },
        "timeline": { "type": "string", "description": "Phased launch layout" },
        "nextSteps": { "type": "array", "items": { "type": "string" }, "description": "Phases to begin" },
        "generatedAt": { "type": "string", "format": "date-time", "description": "Date of contract draft" }
      },
      "required": ["id", "businessId", "businessName", "website", "executiveSummary", "businessProblems", "websiteIssues", "reviewAndReputationIssues", "recommendedServices", "expectedResults", "pricingRecommendations", "timeline", "nextSteps", "generatedAt"]
    },
    "ServicePackagesDraft": {
      "title": "ServicePackagesDraft",
      "description": "Tiered client package proposals generated by specific user",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique packages draft ID" },
        "businessId": { "type": "string", "description": "ID of proposed business" },
        "businessName": { "type": "string", "description": "Name of proposed business" },
        "starter": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "services": { "type": "array", "items": { "type": "string" } },
            "estimatedPricing": { "type": "string" },
            "expectedOutcomes": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["name", "services", "estimatedPricing", "expectedOutcomes"]
        },
        "professional": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "services": { "type": "array", "items": { "type": "string" } },
            "estimatedPricing": { "type": "string" },
            "expectedOutcomes": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["name", "services", "estimatedPricing", "expectedOutcomes"]
        },
        "premium": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "services": { "type": "array", "items": { "type": "string" } },
            "estimatedPricing": { "type": "string" },
            "expectedOutcomes": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["name", "services", "estimatedPricing", "expectedOutcomes"]
        },
        "recommendedPackage": { "type": "string" },
        "generatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "businessId", "businessName", "starter", "professional", "premium", "recommendedPackage", "generatedAt"]
    },
    "OutreachToolkit": {
      "title": "OutreachToolkit",
      "description": "Comprehensive generated outreach materials checklist bundle",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique outreach toolkit ID" },
        "businessId": { "type": "string", "description": "Proposed business lead ID" },
        "businessName": { "type": "string", "description": "Target business title" },
        "coldEmail": {
          "type": "object",
          "properties": {
            "subject": { "type": "string" },
            "body": { "type": "string" }
          },
          "required": ["subject", "body"]
        },
        "linkedInMessage": {
          "type": "object",
          "properties": {
            "body": { "type": "string" }
          },
          "required": ["body"]
        },
        "whatsAppMessage": {
          "type": "object",
          "properties": {
            "body": { "type": "string" }
          },
          "required": ["body"]
        },
        "followUpEmail": {
          "type": "object",
          "properties": {
            "subject": { "type": "string" },
            "body": { "type": "string" }
          },
          "required": ["subject", "body"]
        },
        "salesPitch": {
          "type": "object",
          "properties": {
            "body": { "type": "string" }
          },
          "required": ["body"]
        },
        "generatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "businessId", "businessName", "coldEmail", "linkedInMessage", "whatsAppMessage", "followUpEmail", "salesPitch", "generatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Direct user profile document"
    },
    "/users/{userId}/saved_businesses/{businessId}": {
      "schema": { "$ref": "#/entities/SavedBusiness" },
      "description": "Subcollection storing leads saved by specific registered user"
    },
    "/users/{userId}/search_history/{historyId}": {
      "schema": { "$ref": "#/entities/SearchHistory" },
      "description": "Subcollection logging search runs conducted by specific user"
    },
    "/users/{userId}/website_audits/{auditId}": {
      "schema": { "$ref": "#/entities/WebsiteAudit" },
      "description": "Subcollection logging website audits generated by specific user"
    },
    "/users/{userId}/proposals/{proposalId}": {
      "schema": { "$ref": "#/entities/Proposal" },
      "description": "Subcollection logging client pitch proposals generated by specific user"
    },
    "/users/{userId}/service_packages/{packageId}": {
      "schema": { "$ref": "#/entities/ServicePackagesDraft" },
      "description": "Subcollection logging customized tiered client packages generated by specific user"
    },
    "/users/{userId}/outreach_toolkits/{toolkitId}": {
      "schema": { "$ref": "#/entities/OutreachToolkit" },
      "description": "Subcollection storing full generated agency multi-channel outreach toolkit packages"
    }
  }
}
